<Window x:Class="File2Manager.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="file2manager overlay"
        Width="900"
        Height="520"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        Deactivated="OnDeactivated"
        KeyDown="OnWindowKeyDown">
    <Border Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="OverlaySearchTextBox"
                     FontSize="22"
                     MinHeight="54"
                     TextChanged="OnSearchTextChanged"
                     KeyDown="OnSearchKeyDown"/>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="QuickColumn" Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition x:Name="SmartColumn" Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Quick Search" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListView x:Name="OverlayQuickResultsList"
                              Grid.Row="1"
                              MouseDoubleClick="OnResultOpen">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" DisplayMemberBinding="{Binding FileName}" Width="210"/>
                                <GridViewColumn Header="Modified" DisplayMemberBinding="{Binding ModifiedLocalText}" Width="130"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Smart Search" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListView x:Name="OverlaySmartResultsList"
                              Grid.Row="1"
                              MouseDoubleClick="OnResultOpen">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" DisplayMemberBinding="{Binding FileName}" Width="260"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>

            <TextBlock x:Name="OverlayStatusText"
                       Grid.Row="2"
                       Margin="0,12,0,0"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </Grid>
    </Border>
</Window>
